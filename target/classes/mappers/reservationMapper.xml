<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.spring.springProject3.dao.ReservationDao">
  
  <!-- 예악 정보 저장 처리(결제 전) -->
  <insert id="setReservationInput">
  	insert into reservation values(default, #{vo.mid}, #{vo.name}, #{vo.tel}, #{vo.roomIdx}, #{vo.checkinDate}, #{vo.checkoutDate}, #{vo.guestCount}, #{vo.petCount}, #{vo.totalPrice}, #{vo.status}, default);
  </insert>

  
  
</mapper>